<Window x:Class="TrackEditor.Windowses.LoadTrackPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrackEditor.Windowses"
        mc:Ignorable="d"
        Title="LoadTrackPopup" Height="200" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <Label Content="Initial Scaling"/>
            <TextBox x:Name="InitialScaleTxt" Text="1"/>
            <Label Content="Scale X"/>
            <TextBox x:Name="ScaleXTxt" Text="1"/>
            <Label Content="Scale Y"/>
            <TextBox x:Name="ScaleYTxt" Text="1"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Content="Cancel" Click="Button_Click_1"/>
            <Button Grid.Column="1" Content="OK" Click="Button_Click"/>
        </Grid>
    </Grid>
</Window>
