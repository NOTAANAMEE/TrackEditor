<UserControl x:Class="TrackEditor.Controls.ChangeGraphRotation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrackEditor.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <TextBox x:Name="RotationTxt" Height="20" Text="0.0" KeyDown="Rotation_KeyDown"/>
        <ScrollBar x:Name="RotationBar" Value="0" Orientation="Horizontal" Minimum="-180" Maximum="180" ValueChanged="RotationBar_ValueChanged"/>
    </StackPanel>
</UserControl>
