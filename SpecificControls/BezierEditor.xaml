<UserControl x:Class="SpecificControls.BezierEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpecificControls.Canvases"
             mc:Ignorable="d" 
             x:Name="Root"
             d:DesignHeight="450" d:DesignWidth="800"
             MouseWheel="Root_MouseWheel" Background="Transparent"
             PreviewMouseDown="Root_PreviewMouseDown"
             KeyDown="Root_KeyDown" Focusable="True">
    <Grid>
        <local:MyPointCanvas 
            x:Name="PCanvas" Panel.ZIndex="0" 
            Center="{Binding Center, ElementName=Root}"
            ScaleX="{Binding ScaleX, ElementName=Root}"
            ScaleY="{Binding ScaleY, ElementName=Root}"
            Target="{Binding SelectedGraph.Graph, ElementName=Root}"
            OnClick="Canvas_OnClick"
            SelectedUpdate="Canvas_SelectedUpdate"
            Background="Transparent"/>
        <local:MyCurveCanvas 
            x:Name="CCanvas" Panel.ZIndex="1" 
            Center="{Binding Center, ElementName=Root}"
            ScaleX="{Binding ScaleX, ElementName=Root}"
            ScaleY="{Binding ScaleY, ElementName=Root}"
            Target="{Binding SelectedGraph.Graph, ElementName=Root}"
            OnClick="Canvas_OnClick"
            SelectedUpdate="Canvas_SelectedUpdate"
            Background="Transparent"/>
    </Grid>
</UserControl>
