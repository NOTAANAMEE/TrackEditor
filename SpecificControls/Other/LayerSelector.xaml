<UserControl x:Class="SpecificControls.Other.LayerSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpecificControls.Other"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="Root">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="List"
                     SelectionMode="Single"
                     SelectionChanged="List_SelectionChanged"
                     ItemsSource="{Binding CellInfoCollection, ElementName=Root}"
                     SelectedItem="{Binding SelectedCell, ElementName=Root}"
                     DisplayMemberPath="Name"/>
        </ScrollViewer>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="Btn0" IsEnabled="False" Content="Del" Click="Btn0_Click"/>
            <Button x:Name="Btn3" IsEnabled="False" Content="Deselect" Grid.Column="1" Click="Btn3_Click"/>
            <Button x:Name="Btn1" IsEnabled="False" Content="Up" Grid.Column="2" Click="Btn1_Click"/>
            <Button x:Name="Btn2" IsEnabled="False" Content="Down" Grid.Column="3" Click="Btn2_Click"/>
        </Grid>
    </Grid>
</UserControl>
